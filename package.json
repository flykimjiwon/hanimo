{
  "name": "dev-anywhere",
  "version": "0.1.0",
  "description": "Terminal-based multi-agent AI coding system",
  "type": "module",
  "bin": {
    "devany": "./bin/dev-anywhere",
    "dev-anywhere": "./bin/dev-anywhere"
  },
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "scripts": {
    "dev": "tsx src/cli.ts",
    "build": "tsc",
    "test": "vitest run",
    "test:watch": "vitest",
    "lint": "tsc --noEmit",
    "start": "node dist/cli.js"
  },
  "keywords": [
    "ai",
    "coding-assistant",
    "terminal",
    "multi-agent",
    "cli"
  ],
  "license": "MIT",
  "engines": {
    "node": ">=20.0.0"
  },
  "dependencies": {
    "ai": "^4.0.0",
    "@ai-sdk/openai": "^1.0.0",
    "@ai-sdk/anthropic": "^1.0.0",
    "@ai-sdk/google": "^1.0.0",
    "ink": "^5.0.0",
    "react": "^18.3.0",
    "commander": "^12.0.0",
    "simple-git": "^3.24.0",
    "better-sqlite3": "^11.0.0",
    "zod": "^3.23.0",
    "execa": "^9.0.0",
    "globby": "^14.0.0",
    "crypto-random-string": "^5.0.0"
  },
  "devDependencies": {
    "typescript": "^5.5.0",
    "@types/react": "^18.3.0",
    "@types/better-sqlite3": "^7.6.0",
    "@types/node": "^22.0.0",
    "vitest": "^2.0.0",
    "tsx": "^4.19.0"
  }
}
